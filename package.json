{
  "name": "lidock-monorepo",
  "private": true,
  "description": "Open-source dock runtime for websites and apps",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter playground dev",
    "preview:deploy": "vercel deploy -y",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
